            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            },
            "description": "Test RBAC - DRIVER should NOT be able to access all users (expects 403 Forbidden)"
          },
          "response": []
