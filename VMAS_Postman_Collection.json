    {
      "name": "3. RBAC Testing",
      "description": "Test Role-Based Access Control",
      "item": [
        {
          "name": "Test No Token (Should Fail - 403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 403 Forbidden\", function () {",
                  "    pm.response.to.have.status(403);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/employees",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees"]
            },
            "description": "Test accessing protected endpoint without token - should return 403 Forbidden"
          },
          "response": []
        },
        {
          "name": "DRIVER Access Users (Should Fail - 403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 403 Forbidden\", function () {",
                  "    pm.response.to.have.status(403);",
