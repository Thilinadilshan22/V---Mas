		{
			"name": "1. Add Fuel Log",
			"item": [
				{
					"name": "Add First Log - Good Efficiency Vehicle",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Response has success=true\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.eql(true);",
									"});",
									"",
									"pm.test(\"Response has data object\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data).to.be.an('object');",
									"    pm.expect(jsonData.data.id).to.exist;",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"vehicleRegNumber\": \"KA01AB1234\",\n  \"fuelType\": \"Diesel\",\n  \"liters\": 50.0,\n  \"costPerLiter\": 95.5,\n  \"mileage\": 15000.0,\n  \"date\": \"2026-03-21\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/fuel/add",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"fuel",
								"add"
							]
						},
						"description": "Add first fuel log for vehicle KA01AB1234. This will be used to calculate efficiency when second log is added."
					},
					"response": []
				},
