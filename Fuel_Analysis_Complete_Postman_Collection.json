		{
			"name": "2. Get Summary",
			"item": [
				{
					"name": "Get Current Month Summary",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Summary has all required fields\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data).to.have.property('totalDiesel');",
									"    pm.expect(jsonData.data).to.have.property('totalPetrol');",
									"    pm.expect(jsonData.data).to.have.property('totalVolume');",
									"    pm.expect(jsonData.data).to.have.property('totalCost');",
									"});",
									"",
									"pm.test(\"Total volume equals diesel + petrol\", function () {",
									"    var jsonData = pm.response.json();",
									"    var expected = jsonData.data.totalDiesel + jsonData.data.totalPetrol;",
									"    pm.expect(jsonData.data.totalVolume).to.eql(expected);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/fuel/summary",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"fuel",
								"summary"
							]
						},
						"description": "Get summary for current month with totalDiesel, totalPetrol, totalVolume, and totalCost"
					},
					"response": []
				}
			],
			"description": "Get monthly summary data"
