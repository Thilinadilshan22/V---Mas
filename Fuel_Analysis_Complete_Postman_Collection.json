{
	"info": {
		"_postman_id": "fuel-analysis-module-v3",
		"name": "V-Mas Fuel & Analysis Module - Complete",
		"description": "Complete Postman collection for Fuel & Analysis endpoints.\n\n⚠️ PREREQUISITE: Run 'Login - DRIVER' from the VMAS API collection first. It saves {{driverToken}} to your environment automatically.\n\nAll fuel requests here use {{driverToken}}.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "fuel-module"
	},
	"item": [
		{
			"name": "1. Driver - Add Fuel Log",
			"item": [
				{
					"name": "Add First Log - Good Efficiency Vehicle",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Response has success=true and driverUsername\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.eql(true);",
									"    pm.expect(jsonData.data.id).to.exist;",
									"    pm.expect(jsonData.data.driverUsername).to.exist;",
									"    pm.environment.set(\"fuelLogId\", jsonData.data.id);",
									"    console.log(\"✅ Saved fuelLogId:\", jsonData.data.id);",
									"    console.log(\"✅ driverUsername:\", jsonData.data.driverUsername);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{"key": "token", "value": "{{driverToken}}", "type": "string"}]
						},
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"vehicleRegNumber\": \"KA01AB1234\",\n  \"fuelType\": \"Diesel\",\n  \"liters\": 50.0,\n  \"costPerLiter\": 95.5,\n  \"mileage\": 15000.0,\n  \"date\": \"2026-03-21\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/fuel/add",
							"host": ["{{baseUrl}}"],
							"path": ["api", "fuel", "add"]
						},
						"description": "Driver adds first fuel log. The logged-in driver's username is stored automatically on the record."
					},
					"response": []
				},
				{
					"name": "Add Second Log - Calculate Good Efficiency",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"pm.test(\"Efficiency should be calculated\", function () {",
									"    console.log(\"Expected Efficiency: (15560 - 15000) / 45 = 12.44 km/L (Good)\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{"key": "token", "value": "{{driverToken}}", "type": "string"}]
						},
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"vehicleRegNumber\": \"KA01AB1234\",\n  \"fuelType\": \"Diesel\",\n  \"liters\": 45.0,\n  \"costPerLiter\": 96.0,\n  \"mileage\": 15560.0,\n  \"date\": \"2026-03-22\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/fuel/add",
							"host": ["{{baseUrl}}"],
							"path": ["api", "fuel", "add"]
						},
						"description": "Add second log. Expected efficiency: (15560-15000)/45 = 12.44 km/L"
					},
					"response": []
				},
				{
					"name": "Add Log - Auto Calculate Total Cost",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Total cost auto-calculated\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data.totalCost).to.eql(4080);",
									"    console.log(\"Auto-calculated: 40 * 102 = 4080\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{"key": "token", "value": "{{driverToken}}", "type": "string"}]
						},
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"vehicleRegNumber\": \"KA02CD5678\",\n  \"fuelType\": \"Petrol\",\n  \"liters\": 40.0,\n  \"costPerLiter\": 102.0,\n  \"mileage\": 10000.0,\n  \"date\": \"2026-03-20\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/fuel/add",
							"host": ["{{baseUrl}}"],
							"path": ["api", "fuel", "add"]
						},
						"description": "Test auto-calculation of totalCost (not provided in request). Expected: 40 * 102 = 4080"
					},
					"response": []
				},
				{
					"name": "🚨 Add Log - TRIGGER LOW EFFICIENCY NOTIFICATION",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"pm.test(\"LOW EFFICIENCY ALERT\", function () {",
									"    console.log(\"⚠️ EXPECTED: Notification created!\");",
									"    console.log(\"Efficiency: (10200-10000)/50 = 4.0 km/L < 5 threshold\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{"key": "token", "value": "{{driverToken}}", "type": "string"}]
						},
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"vehicleRegNumber\": \"KA02CD5678\",\n  \"fuelType\": \"Petrol\",\n  \"liters\": 50.0,\n  \"costPerLiter\": 103.0,\n  \"mileage\": 10200.0,\n  \"date\": \"2026-03-21\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/fuel/add",
							"host": ["{{baseUrl}}"],
							"path": ["api", "fuel", "add"]
						},
						"description": "🚨 Should trigger a LOW_EFFICIENCY notification!\n\nCalculation: (10200 - 10000) / 50 = 4.0 km/L < 5 km/L"
					},
					"response": []
				}
			],
			"description": "Driver adds fuel logs. Uses {{driverToken}} from VMAS collection login."
		},
		{
			"name": "2. Driver - View My Logs",
			"item": [
				{
					"name": "Get My Fuel Logs (driver's own history only)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Returns only this driver's logs\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data).to.be.an('array');",
									"    if (jsonData.data.length > 0) {",
									"        var username = jsonData.data[0].driverUsername;",
									"        console.log(\"✅ All logs belong to driver:\", username);",
									"        jsonData.data.forEach(function(log) {",
									"            pm.expect(log.driverUsername).to.eql(username);",
									"        });",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{"key": "token", "value": "{{driverToken}}", "type": "string"}]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/fuel/my-logs",
							"host": ["{{baseUrl}}"],
							"path": ["api", "fuel", "my-logs"]
						},
						"description": "Returns ONLY the fuel logs added by the currently logged-in driver."
					},
					"response": []
				},
				{
					"name": "Get My Fuel Log By ID",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Log belongs to this driver\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data.driverUsername).to.exist;",
									"    console.log(\"✅ driverUsername:\", jsonData.data.driverUsername);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{"key": "token", "value": "{{driverToken}}", "type": "string"}]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/fuel/my-logs/{{fuelLogId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "fuel", "my-logs", "{{fuelLogId}}"]
						},
						"description": "Get a specific log by ID — only succeeds if it belongs to the logged-in driver."
					},
					"response": []
				},
				{
					"name": "❌ Get Another Driver's Log (Should Fail 404)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 404 - Access blocked\", function () {",
									"    pm.response.to.have.status(404);",
									"    console.log(\"✅ Correctly blocked access to another driver's log\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{"key": "token", "value": "{{driverToken}}", "type": "string"}]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/fuel/my-logs/99999",
							"host": ["{{baseUrl}}"],
							"path": ["api", "fuel", "my-logs", "99999"]
						},
						"description": "Security test: ID 99999 doesn't belong to this driver → 404."
					},
					"response": []
				}
			],
			"description": "Driver views only their own logs."
		},
		{
			"name": "3. Driver - Update My Log",
			"item": [
				{
					"name": "Update My Fuel Log",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Log updated successfully\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.eql(true);",
									"    pm.expect(jsonData.data.liters).to.eql(55.0);",
									"    console.log(\"✅ Updated liters:\", jsonData.data.liters);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{"key": "token", "value": "{{driverToken}}", "type": "string"}]
						},
						"method": "PUT",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"vehicleRegNumber\": \"KA01AB1234\",\n  \"fuelType\": \"Diesel\",\n  \"liters\": 55.0,\n  \"costPerLiter\": 95.5,\n  \"mileage\": 15000.0,\n  \"date\": \"2026-03-21\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/fuel/my-logs/{{fuelLogId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "fuel", "my-logs", "{{fuelLogId}}"]
						},
						"description": "Driver updates their own fuel log. Uses {{fuelLogId}} saved from Add step."
					},
					"response": []
				},
				{
					"name": "❌ Update Another Driver's Log (Should Fail 404)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 404 - Update blocked\", function () {",
									"    pm.response.to.have.status(404);",
									"    console.log(\"✅ Correctly blocked update of another driver's log\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{"key": "token", "value": "{{driverToken}}", "type": "string"}]
						},
						"method": "PUT",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"vehicleRegNumber\": \"KA01AB1234\",\n  \"fuelType\": \"Diesel\",\n  \"liters\": 99.9,\n  \"costPerLiter\": 1.0,\n  \"mileage\": 1.0,\n  \"date\": \"2026-03-21\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/fuel/my-logs/99999",
							"host": ["{{baseUrl}}"],
							"path": ["api", "fuel", "my-logs", "99999"]
						},
						"description": "Security test: Log 99999 not owned by this driver → 404."
					},
					"response": []
				}
			],
			"description": "Driver updates only their own logs."
		},
		{
			"name": "4. Analytics (Admin/Shared)",
			"item": [
				{
					"name": "Get Current Month Summary",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Summary has all required fields\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data).to.have.property('totalDiesel');",
									"    pm.expect(jsonData.data).to.have.property('totalPetrol');",
									"    pm.expect(jsonData.data).to.have.property('totalVolume');",
									"    pm.expect(jsonData.data).to.have.property('totalCost');",
									"});"
								],
